{
  "name": "webflow-dashboard-cloud",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "tsc --noEmit",
    "check:core": "npm run check --workspace @create-something/webflow-dashboard-core",
    "test:core": "npm run test --workspace @create-something/webflow-dashboard-core",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@create-something/webflow-dashboard-core": "0.0.1",
    "next": "^15.5.13",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@opennextjs/cloudflare": "1.8.0",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.7.2",
    "wrangler": "^4.74.0"
  }
}
